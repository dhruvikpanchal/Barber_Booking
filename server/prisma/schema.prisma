generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/* ================= ENUMS ================= */

enum Role {
  USER
  BARBER
  ADMIN
}

enum BarberStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum BookingType {
  ONLINE
  WALKIN
}

enum SlotStatus {
  AVAILABLE
  ONLINE_BOOKED
  WALKIN
  BLOCKED
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

/* ================= USER ================= */

model User {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  passwordHash  String?  @map("password_hash")
  phone         String?

  role          Role     @default(USER)

  provider      AuthProvider? 
  providerId    String?  @unique @map("provider_id")

  imageUrl       String? @map("image_url")
  imagePublicId  String? @map("image_public_id")

  isActive      Boolean  @default(true) @map("is_active")
  isEmailVerified Boolean @default(false) @map("is_email_verified")

  resetPasswordOtp     String?   @map("reset_password_otp")
  resetPasswordExpires DateTime? @map("reset_password_expires")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  barber        Barber?
  bookings      Booking[]
  reviews       Review[]

  @@index([email, provider])
  @@map("users")
}

/* ================= BARBER ================= */

model Barber {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique @map("user_id")

  bio             String?
  specialty       String?
  location        String?
  profilePhoto    String?  @map("profile_photo")

  status          BarberStatus @default(PENDING)
  averageRating   Float    @default(0.0) @map("average_rating")

  isAvailable     Boolean  @default(true) @map("is_available")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  services        Service[]
  schedules       Schedule[]
  timeSlots       TimeSlot[]
  bookings        Booking[]
  reviews         Review[]

  @@map("barbers")
}

/* ================= SERVICE ================= */

model Service {
  id               Int      @id @default(autoincrement())
  barberId         Int      @map("barber_id")

  name             String
  description      String?
  durationMinutes  Int      @map("duration_minutes")
  price            Float

  isActive         Boolean  @default(true) @map("is_active")

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  barber           Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  bookings         Booking[]

  @@map("services")
}

/* ================= SCHEDULE ================= */

model Schedule {
  id         Int      @id @default(autoincrement())
  barberId   Int      @map("barber_id")

  dayOfWeek  Int      @map("day_of_week")
  startTime  DateTime @db.Time @map("start_time")
  endTime    DateTime @db.Time @map("end_time")

  isDayOff   Boolean  @default(false) @map("is_day_off")

  barber     Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barberId, dayOfWeek])
  @@map("schedules")
}

/* ================= TIME SLOT ================= */

model TimeSlot {
  id         Int      @id @default(autoincrement())
  barberId   Int      @map("barber_id")

  slotDate   DateTime @db.Date @map("slot_date")
  startTime  DateTime @db.Time @map("start_time")
  endTime    DateTime @db.Time @map("end_time")

  status     SlotStatus @default(AVAILABLE)

  createdAt  DateTime @default(now()) @map("created_at")

  barber     Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)

  booking    Booking? @relation("SlotBooking")

  @@unique([barberId, slotDate, startTime])
  @@index([barberId, slotDate, status])
  @@map("time_slots")
}

/* ================= BOOKING ================= */

model Booking {
  id            Int      @id @default(autoincrement())

  userId        Int?     @map("user_id")
  barberId      Int      @map("barber_id")
  serviceId     Int      @map("service_id")

  slotId        Int      @unique @map("slot_id")

  bookingType   BookingType @map("booking_type")
  walkInName    String?

  bookedAt      DateTime

  status        BookingStatus @default(PENDING)

  cancelReason  String?
  notes         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User?    @relation(fields: [userId], references: [id])
  barber        Barber   @relation(fields: [barberId], references: [id])
  service       Service  @relation(fields: [serviceId], references: [id])

  slot          TimeSlot @relation("SlotBooking", fields: [slotId], references: [id])

  review        Review?
}

/* ================= REVIEW ================= */

model Review {
  id         Int      @id @default(autoincrement())

  bookingId  Int      @unique @map("booking_id")
  userId     Int      @map("user_id")
  barberId   Int      @map("barber_id")

  rating     Int
  comment    String?

  createdAt  DateTime @default(now()) @map("created_at")

  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  barber     Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

/* ================= CONTACT ================= */

model ContactMessage {
  id         Int      @id @default(autoincrement())

  name       String
  email      String
  phone      String?
  service_need String?
  message    String
  status     String

  createdAt  DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}