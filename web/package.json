{
  "name": "client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx scripts/start-dev.mjs",
    "predev": "node scripts/clear-next-dev-lock.mjs",
    "dev:next": "next dev",
    "prebuild": "node scripts/ensure-build-ready.mjs",
    "build": "next build",
    "postbuild": "node scripts/prepare-standalone.mjs && node scripts/extract-standalone-config.mjs",
    "prestart": "node scripts/check-db.mjs",
    "start": "tsx scripts/start-prod.mjs",
    "clean": "node scripts/clean-next-cache.mjs",
    "stop": "node scripts/stop-server.mjs",
    "start:standalone": "node scripts/extract-standalone-config.mjs && node .next/standalone/server.js",
    "start:next": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/baseline-drizzle-migrations.mjs && drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --tsconfig tsconfig.json src/server/db/seed.ts"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.5.2",
    "@sentry/nextjs": "^10.56.0",
    "@tanstack/react-query": "^5.101.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.14.0",
    "next": "16.2.5",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^7.0.13",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "recharts": "^3.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tsx": "^4.22.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.5",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^6.0.3"
  }
}
